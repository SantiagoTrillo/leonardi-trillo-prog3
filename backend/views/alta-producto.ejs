<%- include('partials/head') %>
<link rel="stylesheet" href="/alta-producto/alta-producto.css">
<script src="/alta-producto/alta-producto.js" defer></script>
<body class="pagina-productos">
    <div class="marco-aplicacion d-flex flex-column">
        <%- include('partials/nav') %>
        <main class="contenido-formulario d-flex flex-grow-1 align-items-center justify-content-center p-4">
            <div class="card-formulario-admin">
                <h1 class="titulo-alta-admin text-center">Alta de producto</h1>
                <div class="divider-admin"></div>
                <form class="formulario-alta d-flex flex-column gap-4" method="POST" action="/admin/alta-producto" enctype="multipart/form-data">
                    <div class="campo-fila-admin">
                        <span class="label-admin">Categoría:</span>
                        <div class="dropdown w-100">
                            <button class="btn btn-outline-light dropdown-toggle w-100 btn-dropdown-admin text-start d-flex justify-content-between align-items-center" type="button" id="dropdownCategoria" data-bs-toggle="dropdown" aria-expanded="false">
                                <span id="selectedCategoriaText">Seleccione Categoría</span>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-dark w-100 glass-dropdown" aria-labelledby="dropdownCategoria">
                                <li><button class="dropdown-item option-categoria" type="button" data-value="pelicula">Película</button></li>
                                <li><button class="dropdown-item option-categoria" type="button" data-value="serie">Serie</button></li>
                            </ul>
                            <input type="text" id="inputCategoria" name="tipo" class="validador-invisible" required>
                        </div>
                    </div>
                    <div class="campo-fila-admin">
                        <label class="label-admin" for="tituloProducto">Título:</label>
                        <input class="form-control campo-input-admin" type="text" id="tituloProducto" name="titulo" placeholder="Título" required>
                    </div>
                    <div class="campo-fila-admin">
                        <label class="label-admin" for="precioProducto">Precio:</label>
                        <input class="form-control campo-input-admin" type="number" id="precioProducto" name="precio" placeholder="Precio" min="0" required>
                    </div>
                    <div class="campo-fila-admin">
                        <label class="label-admin" for="imagenProducto">Imagen:</label>
                        <input class="form-control campo-input-admin" type="file" id="imagenProducto" name="imagen" accept="image/*" required>
                    </div>
                    <div class="campo-fila-admin">
                        <span class="label-admin">Estado:</span>
                        <div class="dropdown w-100">
                            <button class="btn btn-outline-light dropdown-toggle w-100 btn-dropdown-admin text-start d-flex justify-content-between align-items-center" type="button" id="dropdownEstado" data-bs-toggle="dropdown" aria-expanded="false">
                                <span id="selectedEstadoText">Activo</span>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-dark w-100 glass-dropdown" aria-labelledby="dropdownEstado">
                                <li><button class="dropdown-item option-estado" type="button" data-value="activo">Activo</button></li>
                                <li><button class="dropdown-item option-estado" type="button" data-value="inactivo">Inactivo</button></li>
                            </ul>
                            <input type="hidden" id="inputEstado" name="estado" value="activo" required>
                        </div>
                    </div>
                    <div class="divider-admin"></div>
                    <div class="d-flex gap-3">
                        <a href="/admin/dashboard" class="btn boton-volver w-50">Volver</a>
                        <button class="btn btn-dark boton-continuar w-50" type="submit">Agregar</button>
                    </div>
                </form>
            </div>
        </main>
    </div>
</body>
</html>