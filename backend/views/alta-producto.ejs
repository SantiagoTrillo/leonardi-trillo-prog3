<%- include('partials/head') %>
<link rel="stylesheet" href="/css/alta-producto.css">
<body class="pagina-productos">
    <div class="marco-aplicacion d-flex flex-column">
        <%- include('partials/nav') %>
        <main class="contenido-formulario d-flex flex-grow-1 align-items-center justify-content-center p-4">
            <div class="card-formulario-admin">
                <h1 class="titulo-alta-admin text-center">Alta de producto</h1>
                <div class="divider-admin"></div>
                <form class="formulario-alta d-flex flex-column gap-4" method="POST" action="/admin/alta-producto" enctype="multipart/form-data">
                    <div class="campo-columna-admin">
                        <label class="label-admin" for="inputCategoria">Categoría:</label>
                        <select class="form-select campo-input-admin dropdown-select-admin" id="inputCategoria" name="tipo" onchange="this.blur()" required>
                            <option value="" disabled selected>Seleccione Categoría</option>
                            <option value="pelicula">Película</option>
                            <option value="serie">Serie</option>
                        </select>
                    </div>
                    <div class="campo-columna-admin">
                        <label class="label-admin" for="tituloProducto">Título:</label>
                        <input class="form-control campo-input-admin" type="text" id="tituloProducto" name="titulo" placeholder="Título" required>
                    </div>
                    <div class="campo-columna-admin">
                        <label class="label-admin" for="precioProducto">Precio:</label>
                        <input class="form-control campo-input-admin" type="number" id="precioProducto" name="precio" placeholder="Precio" min="0" required>
                    </div>
                    <div class="campo-columna-admin">
                        <label class="label-admin" for="imagenProducto">Imagen:</label>
                        <input type="file" id="imagenProducto" name="imagen" accept="image/*" class="form-control campo-input-admin" required>
                    </div>
                    <div class="campo-columna-admin">
                        <label class="label-admin" for="inputEstado">Estado:</label>
                        <select class="form-select campo-input-admin dropdown-select-admin" id="inputEstado" name="estado" onchange="this.blur()" required>
                            <option value="activo" selected>Activo</option>
                            <option value="inactivo">Inactivo</option>
                        </select>
                    </div>
                    <div class="divider-admin"></div>
                    <div class="d-flex gap-3">
                        <a href="/admin/dashboard" class="btn boton-volver w-50">Volver</a>
                        <button class="btn btn-dark boton-continuar w-50" type="submit">Agregar</button>
                    </div>
                </form>
            </div>
        </main>
    </div>
</body>
</html>