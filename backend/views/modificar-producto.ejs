<%- include('partials/head') %>
<link rel="stylesheet" href="/css/modificar-producto.css">
<body class="pagina-productos">
    <div class="marco-aplicacion d-flex flex-column">
        <%- include('partials/nav') %>
        <main class="contenido-formulario d-flex flex-grow-1 align-items-center justify-content-center p-4">
            <div class="card-formulario-admin">
                <h1 class="titulo-alta-admin text-center">Modificación de producto</h1>
                <div class="divider-admin"></div>
                <form class="formulario-alta d-flex flex-column gap-4" method="POST" action="/admin/modificar-producto" enctype="multipart/form-data">
                    <input type="hidden" name="id" value="<%= product.id %>">
                    <div class="campo-columna-admin">
                        <label class="label-admin" for="inputCategoria">Categoría:</label>
                        <select class="form-select campo-input-admin dropdown-select-admin" id="inputCategoria" name="tipo" onchange="this.blur()" required>
                            <option value="pelicula" <%= product.tipo === 'pelicula' ? 'selected' : '' %>>Película</option>
                            <option value="serie" <%= product.tipo === 'serie' ? 'selected' : '' %>>Serie</option>
                        </select>
                    </div>
                    <div class="campo-columna-admin">
                        <label class="label-admin" for="tituloProducto">Título:</label>
                        <input class="form-control campo-input-admin" type="text" id="tituloProducto" name="titulo" value="<%= product.titulo %>" placeholder="Título" required>
                    </div>
                    <div class="campo-columna-admin">
                        <label class="label-admin" for="precioProducto">Precio:</label>
                        <input class="form-control campo-input-admin" type="number" id="precioProducto" name="precio" value="<%= product.precio %>" placeholder="Precio" min="0" required>
                    </div>
                    <div class="campo-columna-admin">
                        <label class="label-admin" for="imagenProducto">Imagen:</label>
                        <div class="w-100">
                            <input type="file" id="imagenProducto" name="imagen" accept="image/*" class="form-control campo-input-admin">
                            <input type="hidden" name="imagenExistente" value="<%= product.imagen %>">
                        </div>
                    </div>
                    <div class="campo-columna-admin">
                        <label class="label-admin" for="inputEstado">Estado:</label>
                        <select class="form-select campo-input-admin dropdown-select-admin" id="inputEstado" name="estado" onchange="this.blur()" required>
                            <option value="activo" <%= product.estado === 'activo' ? 'selected' : '' %>>Activo</option>
                            <option value="inactivo" <%= product.estado === 'inactivo' ? 'selected' : '' %>>Inactivo</option>
                        </select>
                    </div>
                    <div class="divider-admin"></div>
                    <div class="d-flex gap-3">
                        <a href="/admin/dashboard" class="btn boton-volver w-50">Volver</a>
                        <button class="btn btn-dark boton-continuar w-50" type="submit">Confirmar</button>
                    </div>
                </form>
            </div>
        </main>
    </div>
    <div class="modal fade modal-activar" id="modalActivar" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content tarjeta-modal border-0">
                <p class="texto-modal">¿Seguro que desea activar el producto?</p>
                <div class="d-flex justify-content-center gap-3 w-100">
                    <button class="btn btn-dark boton-modal-confirmar" id="btnConfirmarActivar" type="button">Confirmar</button>
                    <button class="btn btn-outline-light boton-modal-cancelar" id="btnCancelarActivar" type="button">Cancelar</button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal fade modal-desactivar" id="modalDesactivar" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content tarjeta-modal border-0">
                <p class="texto-modal">¿Seguro que desea desactivar el producto?</p>
                <div class="d-flex justify-content-center gap-3 w-100">
                    <button class="btn btn-dark boton-modal-confirmar" id="btnConfirmarDesactivar" type="button">Confirmar</button>
                    <button class="btn btn-outline-light boton-modal-cancelar" id="btnCancelarDesactivar" type="button">Cancelar</button>
                </div>
            </div>
        </div>
    </div>
    <script>
    document.addEventListener("DOMContentLoaded", () => {
        const selectEstado = document.getElementById("inputEstado");
        let estadoInicial = selectEstado.value;
        
        const modalActivarEl = document.getElementById("modalActivar");
        const modalDesactivarEl = document.getElementById("modalDesactivar");
        
        const modalActivar = new bootstrap.Modal(modalActivarEl);
        const modalDesactivar = new bootstrap.Modal(modalDesactivarEl);
        
        let confirmando = false;

        selectEstado.addEventListener("change", () => {
            if (confirmando) return;
            
            const nuevoEstado = selectEstado.value;
            if (nuevoEstado !== estadoInicial) {
                if (nuevoEstado === "activo") {
                    modalActivar.show();
                } else if (nuevoEstado === "inactivo") {
                    modalDesactivar.show();
                }
            }
        });

        document.getElementById("btnConfirmarActivar").addEventListener("click", () => {
            estadoInicial = selectEstado.value;
            modalActivar.hide();
            selectEstado.blur();
        });
        document.getElementById("btnConfirmarDesactivar").addEventListener("click", () => {
            estadoInicial = selectEstado.value;
            modalDesactivar.hide();
            selectEstado.blur();
        });

        const restaurarEstado = () => {
            confirmando = true;
            selectEstado.value = estadoInicial;
            confirmando = false;
        };

        document.getElementById("btnCancelarActivar").addEventListener("click", () => {
            restaurarEstado();
            modalActivar.hide();
        });
        document.getElementById("btnCancelarDesactivar").addEventListener("click", () => {
            restaurarEstado();
            modalDesactivar.hide();
        });

        modalActivarEl.addEventListener("hidden.bs.modal", () => {
            if (selectEstado.value === "activo" && estadoInicial !== "activo") {
                restaurarEstado();
            }
        });
        modalDesactivarEl.addEventListener("hidden.bs.modal", () => {
            if (selectEstado.value === "inactivo" && estadoInicial !== "inactivo") {
                restaurarEstado();
            }
        });
    });
    </script>
</body>
</html>