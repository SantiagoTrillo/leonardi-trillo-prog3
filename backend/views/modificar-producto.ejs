<%- include('partials/head') %>
<link rel="stylesheet" href="/modificar-producto/modificar-producto.css">
<script src="/modificar-producto/modificar-producto.js" defer></script>
<body class="pagina-productos">
    <div class="marco-aplicacion d-flex flex-column">
        <%- include('partials/nav') %>
        <main class="contenido-formulario d-flex flex-grow-1 align-items-center justify-content-center p-4">
            <div class="card-formulario-admin">
                <h1 class="titulo-alta-admin text-center">Modificación de producto</h1>
                <div class="divider-admin"></div>
                <form class="formulario-alta d-flex flex-column gap-4" method="POST" action="/admin/modificar-producto" enctype="multipart/form-data">
                    <input type="hidden" name="id" value="<%= product.id %>">
                    <div class="campo-fila-admin">
                        <span class="label-admin">Categoría:</span>
                        <div class="dropdown w-100">
                            <button class="btn btn-outline-light dropdown-toggle w-100 btn-dropdown-admin text-start d-flex justify-content-between align-items-center" type="button" id="dropdownCategoria" data-bs-toggle="dropdown" aria-expanded="false">
                                <span id="selectedCategoriaText"><%= product.tipo === 'pelicula' ? 'Película' : 'Serie' %></span>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-dark w-100 glass-dropdown" aria-labelledby="dropdownCategoria">
                                <li><button class="dropdown-item option-categoria" type="button" data-value="pelicula">Película</button></li>
                                <li><button class="dropdown-item option-categoria" type="button" data-value="serie">Serie</button></li>
                            </ul>
                            <input type="text" id="inputCategoria" name="tipo" value="<%= product.tipo %>" class="validador-invisible" required>
                        </div>
                    </div>
                    <div class="campo-fila-admin">
                        <label class="label-admin" for="tituloProducto">Título:</label>
                        <input class="form-control campo-input-admin" type="text" id="tituloProducto" name="titulo" value="<%= product.titulo %>" placeholder="Título" required>
                    </div>
                    <div class="campo-fila-admin">
                        <label class="label-admin" for="precioProducto">Precio:</label>
                        <input class="form-control campo-input-admin" type="number" id="precioProducto" name="precio" value="<%= product.precio %>" placeholder="Precio" min="0" required>
                    </div>
                    <div class="campo-fila-admin">
                        <span class="label-admin">Imagen:</span>
                        <div class="custom-file-upload-container">
                            <label for="imagenProducto" class="custom-file-upload-label d-flex align-items-center justify-content-between m-0">
                                <span id="file-upload-text" class="text-truncate file-selected"><%= product.imagen %></span>
                                <span class="custom-file-upload-btn"><i class="fa-solid fa-cloud-arrow-up"></i> Examinar</span>
                            </label>
                            <div id="file-name-tooltip" class="file-name-tooltip-content has-file"><%= product.imagen %></div>
                            <input type="file" id="imagenProducto" name="imagen" accept="image/*" class="validador-invisible">
                            <input type="hidden" name="imagenExistente" value="<%= product.imagen %>">
                        </div>
                    </div>
                    <div class="campo-fila-admin">
                        <span class="label-admin">Estado:</span>
                        <div class="dropdown w-100">
                            <button class="btn btn-outline-light dropdown-toggle w-100 btn-dropdown-admin text-start d-flex justify-content-between align-items-center" type="button" id="dropdownEstado" data-bs-toggle="dropdown" aria-expanded="false">
                                <span id="selectedEstadoText"><%= product.estado === 'activo' ? 'Activo' : 'Inactivo' %></span>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-dark w-100 glass-dropdown" aria-labelledby="dropdownEstado">
                                <li><button class="dropdown-item option-estado" type="button" data-value="activo">Activo</button></li>
                                <li><button class="dropdown-item option-estado" type="button" data-value="inactivo">Inactivo</button></li>
                            </ul>
                            <input type="hidden" id="inputEstado" name="estado" value="<%= product.estado %>" required>
                        </div>
                    </div>
                    <div class="divider-admin"></div>
                    <div class="d-flex gap-3">
                        <a href="/admin/dashboard" class="btn boton-volver w-50">Volver</a>
                        <button class="btn btn-dark boton-continuar w-50" type="submit">Confirmar</button>
                    </div>
                </form>
            </div>
        </main>
    </div>
    <%- include('partials/modal-confirmacion', { id: 'modalActivar', pregunta: '¿Seguro que desea activar el producto?', idBotonConfirmar: 'botonConfirmarActivar', idBotonCancelar: 'botonCancelarActivar' }) %>
    <%- include('partials/modal-confirmacion', { id: 'modalDesactivar', pregunta: '¿Seguro que desea desactivar el producto?', idBotonConfirmar: 'botonConfirmarDesactivar', idBotonCancelar: 'botonCancelarDesactivar' }) %>
</body>
</html>