
<%- include('partials/header') %>

<link rel="stylesheet" href="/panel-control/panel-control.css">
<script src="/panel-control/panel-control.js" defer></script>

<body class="pagina-productos">
    <div class="marco-aplicacion d-flex flex-column">
        <nav class="barra-superior">
            <div class="contenido-barra-superior">
                <div class="seccion-izquierda d-flex align-items-center gap-3">
                    <a class="btn-home" href="/bienvenida/bienvenida.html" id="btnHome" aria-label="Ir al inicio">
                        <i class="fa-solid fa-house"></i>
                    </a>
                    <button class="btn-tema" id="btnTema" aria-label="Cambiar tema" type="button">
                        <i class="fa-solid fa-moon"></i>
                    </button>
                </div>
                <span class="nombre-aplicacion">CineStream</span>
                <div class="seccion-derecha">
                    <p class="autores">Hecho por: Santiago Leonardi y Santiago Trillo</p>
                </div>
            </div>
        </nav>
        <div class="cuerpo-productos d-flex flex-grow-1">
            <aside class="panel-izquierdo d-flex flex-column align-items-center justify-content-between p-3">
                <div class="d-flex flex-column w-100 gap-3">
                    <button class="btn-catalogo active" id="btnSeries" type="button">Catálogo de series</button>
                    <button class="btn-catalogo" id="btnPeliculas" type="button">Catálogo de películas</button>
                </div>
                <a href="/admin/alta-producto" class="btn-cargar-producto text-center w-100" id="btnCargar">Cargar producto</a>
            </aside>
            <main class="panel-central d-flex flex-column flex-grow-1 p-4">
                <div class="cabecera-panel-central text-center mb-4">
                    <h1 class="titulo-seccion-admin">Menú de administración de productos</h1>
                </div>
                <div class="lista-administracion flex-grow-1 overflow-auto d-flex flex-column gap-3" id="listaAdministracion">
                    <% const productosOrdenados = productos.sort((a, b) => (a.estado === 'activo' ? -1 : 1)); %>
                    <% productosOrdenados.forEach(function(product) { %>
                        <div class="item-producto-admin d-flex align-items-center justify-content-between p-3 tipo-<%= product.tipo %> <%= product.estado === 'inactivo' ? 'inactivo' : '' %>" data-id="<%= product.id %>" data-tipo="<%= product.tipo %>" data-estado="<%= product.estado %>">
                            <div class="info-izquierda-admin d-flex align-items-center gap-3">
                                <div class="wrapper-poster-admin">
                                    <img src="<%= product.imagen %>" alt="<%= product.titulo %>" class="poster-admin">
                                </div>
                                <div class="detalle-info-admin d-flex flex-column gap-1">
                                    <div><strong>Título:</strong> <%= product.titulo %></div>
                                    <div><strong>Precio:</strong> $<%= product.precio %></div>
                                    <div><strong>Estado:</strong> <span class="badge-estado state-<%= product.estado %>"><%= product.estado.charAt(0).toUpperCase() + product.estado.slice(1) %></span></div>
                                </div>
                            </div>
                            <div class="acciones-admin d-flex gap-3 align-items-center">
                                <a href="/admin/modificar-producto?id=<%= product.id %>" class="btn-accion-admin btn-editar-admin" aria-label="Editar producto">
                                    <i class="fa-solid fa-pencil"></i>
                                </a>
                                <button class="btn-accion-admin btn-borrar-admin <%= product.estado === 'inactivo' ? 'd-none' : '' %>" data-id="<%= product.id %>" aria-label="Borrar producto" type="button">
                                    <i class="fa-solid fa-trash-can"></i>
                                </button>
                            </div>
                        </div>
                    <% }); %>
                </div>
            </main>
        </div>
    </div>
</body>
</html>