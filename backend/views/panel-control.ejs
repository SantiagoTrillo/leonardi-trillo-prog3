<%- include('partials/head') %>
<link rel="stylesheet" href="/css/panel-control.css">
<body class="pagina-productos">
    <div class="marco-aplicacion d-flex flex-column">
        <%- include('partials/nav') %>
        <div class="cuerpo-productos d-flex flex-grow-1">
            <aside class="panel-izquierdo d-flex flex-column align-items-center justify-content-between p-3">
                <div class="d-flex flex-column w-100 gap-3">
                    <a href="/admin/dashboard?tipo=serie" class="btn-catalogo <%= tipoActual === 'serie' ? 'active' : '' %> text-decoration-none">Catálogo de series</a>
                    <a href="/admin/dashboard?tipo=pelicula" class="btn-catalogo <%= tipoActual === 'pelicula' ? 'active' : '' %> text-decoration-none">Catálogo de películas</a>
                </div>
                <a href="/admin/alta-producto" class="btn-cargar-producto text-center w-100" id="btnCargar">Cargar producto</a>
            </aside>
            <main class="panel-central d-flex flex-column flex-grow-1 p-4">
                <div class="cabecera-panel-central text-center mb-4"><h1 class="titulo-seccion-admin">Menú de administración de productos</h1>
                </div>
                <div class="lista-administracion flex-grow-1 overflow-auto d-flex flex-column gap-3" id="listaAdministracion">
                    <% 
                    const productosOrdenados = productos.sort((a, b) => {
                        if (a.estado === 'activo' && b.estado !== 'activo') return -1;
                        if (a.estado !== 'activo' && b.estado === 'activo') return 1;
                        return a.titulo.localeCompare(b.titulo);
                    });
                    let mostroSeparador = false;
                    productosOrdenados.forEach(function(producto) { 
                        if (producto.estado === 'inactivo' && !mostroSeparador) {
                            mostroSeparador = true;
                    %>
                            <div class="divisor-productos-inactivos" id="divisorInactivos">
                                <span class="texto-divisor-inactivos">Productos Inactivos</span>
                            </div>
                    <% 
                        } 
                    %>
                        <div class="item-producto-admin d-flex align-items-center justify-content-between p-3 tipo-<%= producto.tipo %> <%= producto.estado === 'inactivo' ? 'inactivo' : '' %>" data-id="<%= producto.id %>" data-tipo="<%= producto.tipo %>" data-estado="<%= producto.estado %>" data-titulo="<%= producto.titulo %>">
                            <div class="info-izquierda-admin d-flex align-items-center gap-3">
                                <div class="wrapper-poster-admin">
                                    <img src="<%= producto.imagen %>" alt="<%= producto.titulo %>" class="poster-admin">
                                </div>
                                <div class="detalle-info-admin d-flex flex-column gap-1">
                                    <div><strong>Título:</strong> <%= producto.titulo %></div>
                                    <div><strong>Precio:</strong> $<%= producto.precio %></div>
                                    <div><strong>Estado:</strong> <span class="badge-estado state-<%= producto.estado %>"><%= producto.estado %></span></div>
                                </div>
                            </div>
                            <div class="acciones-admin d-flex gap-3 align-items-center">
                                <a href="/admin/modificar-producto?id=<%= producto.id %>" class="btn-accion-admin btn-editar-admin" aria-label="Editar producto"><i class="fa-solid fa-pencil"></i></a>
                                <button class="btn-accion-admin btn-activar-admin <%= producto.estado === 'activo' ? 'd-none' : '' %>" data-bs-toggle="modal" data-bs-target="#modalActivar-<%= producto.id %>" aria-label="Activar producto" type="button"><i class="fa-solid fa-power-off"></i></button>
                                <button class="btn-accion-admin btn-borrar-admin <%= producto.estado === 'inactivo' ? 'd-none' : '' %>" data-bs-toggle="modal" data-bs-target="#modalDesactivar-<%= producto.id %>" aria-label="Borrar producto" type="button"><i class="fa-solid fa-trash-can"></i></button>
                            </div>
                        </div>

                        <!-- Modal Desactivar para este producto -->
                        <div class="modal fade modal-desactivar" id="modalDesactivar-<%= producto.id %>" tabindex="-1" aria-hidden="true">
                            <div class="modal-dialog modal-dialog-centered">
                                <div class="modal-content tarjeta-modal border-0">
                                    <p class="texto-modal">¿Seguro que desea desactivar a "<%= producto.titulo %>"?</p>
                                    <div class="d-flex justify-content-center gap-3 w-100">
                                        <form action="/admin/modificar-producto" method="POST" class="m-0 p-0 w-100 d-flex justify-content-center gap-3">
                                            <input type="hidden" name="id" value="<%= producto.id %>">
                                            <input type="hidden" name="estado" value="inactivo">
                                            <button class="btn btn-dark boton-modal-confirmar" type="submit">Confirmar</button>
                                            <button class="btn btn-outline-light boton-modal-cancelar" data-bs-dismiss="modal" type="button">Cancelar</button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Modal Activar para este producto -->
                        <div class="modal fade modal-activar" id="modalActivar-<%= producto.id %>" tabindex="-1" aria-hidden="true">
                            <div class="modal-dialog modal-dialog-centered">
                                <div class="modal-content tarjeta-modal border-0">
                                    <p class="texto-modal">¿Seguro que desea activar a "<%= producto.titulo %>"?</p>
                                    <div class="d-flex justify-content-center gap-3 w-100">
                                        <form action="/admin/modificar-producto" method="POST" class="m-0 p-0 w-100 d-flex justify-content-center gap-3">
                                            <input type="hidden" name="id" value="<%= producto.id %>">
                                            <input type="hidden" name="estado" value="activo">
                                            <button class="btn btn-dark boton-modal-confirmar" type="submit">Confirmar</button>
                                            <button class="btn btn-outline-light boton-modal-cancelar" data-bs-dismiss="modal" type="button">Cancelar</button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                    <% if (!mostroSeparador) { %>
                        <div class="divisor-productos-inactivos d-none" id="divisorInactivos">
                            <span class="texto-divisor-inactivos">Productos Inactivos</span>
                        </div>
                    <% } %>
                </div>
            </main>
        </div>
    </div>

</body>
</html>